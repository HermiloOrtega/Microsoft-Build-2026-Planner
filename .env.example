# ── App ────────────────────────────────────────────────────────────────────────
NODE_ENV=development          # set to "production" on the server
PORT=3001

# ── Database ───────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=MS_Build_26

# ── CORS (production only) ─────────────────────────────────────────────────────
# Set to your domain, e.g. https://build-planner.yourdomain.com
# Leave blank locally (defaults to http://localhost:5173)
CORS_ORIGIN=

# ── Master password ─────────────────────────────────────────────────────────────
# Required to perform any write operation (POST/PUT/DELETE) via the API.
# Leave blank to disable protection (not recommended in production).
MASTER_PASSWORD=
